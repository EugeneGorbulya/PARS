# ─── PostgreSQL ─────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=smartrent

# Used by host tooling (alembic, psql) when talking to the dockerised db:
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/smartrent

# ─── Redis (cache + Celery broker, if enabled) ──────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── S3 / MinIO ─────────────────────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=smartrent-media

# ─── Telegram bot ───────────────────────────────────────────────────────────
# Token from @BotFather.
BOT_TOKEN=

# ─── External APIs ──────────────────────────────────────────────────────────
# 2GIS Public Transport API key (https://platform.2gis.ru/). If empty, the
# pluggable geo provider falls back to a deterministic mock.
DGIS_API_KEY=

# CIAN parser: 1 = real HTTP requests, 0/empty = canned fixtures.
CIAN_LIVE=1

# Auto-fetch new flats in the background when the per-profile unrated buffer
# drops below a threshold. Disabled by default so that the rating dataset
# stays reproducible during evaluation.
CIAN_FETCH_ENABLED=false

# Use minimal CIAN search filters in offline tests.
MINIMAL=1
